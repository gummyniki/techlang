!import(std.tec) as std;

function main() returns none {
    int x = 42;
    float f = x as float;
    std.print_float(f); // 42.000000

    std.print_newline();

    float pi = 3.14;
    int i = pi as int;
    std.print_int(i); // 3

    std.print_newline();

    int code = 65;
    char c = code as char;
    std.print_char(c); // A
}
