!import(std.tec) as std;

function increment(int *p) returns none {
    p.value += 1;
}

function swap(int *a, int *b) returns none {
    int temp = a.value;
    a.value = b.value;
    b.value = temp;
}

function main() returns none {
    int x = 5;
    increment(x.address);
    std.print_int(x); // 6
    std.print_newline();

    int a = 10;
    int b = 20;
    swap(a.address, b.address);
    std.print_int(a); // 20
    std.print_newline();
    std.print_int(b); // 10
    
}
